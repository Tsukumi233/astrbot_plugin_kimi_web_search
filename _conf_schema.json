{
  "connection_settings": {
    "type": "object",
    "description": "连接设置",
    "hint": "Kimi OpenAI-compatible Chat Completions 连接参数",
    "items": {
      "api_key": {
        "type": "string",
        "description": "Kimi API Key",
        "hint": "标准 Kimi API 使用 Moonshot API Key；Kimi coding plan 使用对应 API Key。",
        "default": ""
      },
      "base_url": {
        "type": "string",
        "description": "Base URL",
        "hint": "标准 Kimi API: https://api.moonshot.cn/v1；coding plan 可改为 https://api.kimi.com/coding/v1",
        "default": "https://api.moonshot.cn/v1"
      },
      "model": {
        "type": "string",
        "description": "模型 ID",
        "hint": "标准 Kimi API 可用 kimi-k2.6；coding plan 可用 kimi-for-coding",
        "default": "kimi-k2.6"
      },
      "timeout_seconds": {
        "type": "int",
        "description": "请求超时时间（秒）",
        "default": 60,
        "slider": {
          "min": 5,
          "max": 180,
          "step": 1
        }
      },
      "reuse_session": {
        "type": "bool",
        "description": "复用 HTTP 会话",
        "hint": "高频调用时可开启，降低连接开销",
        "default": false
      },
      "proxy": {
        "type": "string",
        "description": "HTTP 代理",
        "hint": "例如 http://127.0.0.1:7890，留空则不使用代理",
        "default": ""
      },
      "user_agent": {
        "type": "string",
        "description": "自定义 User-Agent",
        "hint": "标准 Kimi API 通常留空；coding plan 可填 KimiCLI/1.30.0",
        "default": ""
      }
    }
  },
  "request_settings": {
    "type": "object",
    "description": "请求设置",
    "hint": "控制 Chat Completions 请求",
    "items": {
      "max_content_chars": {
        "type": "int",
        "description": "网页获取工具最大返回字符数",
        "default": 4000,
        "slider": {
          "min": 500,
          "max": 12000,
          "step": 500
        }
      },
      "max_tokens": {
        "type": "int",
        "description": "最大输出 Token",
        "default": 8192,
        "slider": {
          "min": 1024,
          "max": 32768,
          "step": 1024
        }
      },
      "temperature": {
        "type": "float",
        "description": "温度",
        "default": 0.6,
        "slider": {
          "min": 0,
          "max": 1,
          "step": 0.1
        }
      },
      "disable_thinking": {
        "type": "bool",
        "description": "禁用思考能力",
        "hint": "Kimi 官方文档要求使用 $web_search 时禁用思考能力",
        "default": true
      },
      "max_tool_rounds": {
        "type": "int",
        "description": "最大工具调用轮数",
        "hint": "防止异常循环",
        "default": 6,
        "slider": {
          "min": 1,
          "max": 12,
          "step": 1
        }
      }
    }
  },
  "tool_settings": {
    "type": "object",
    "description": "工具设置",
    "hint": "控制 LLM Tool 和 Skill",
    "items": {
      "enable_fetch": {
        "type": "bool",
        "description": "启用网页获取工具",
        "hint": "启用后 AI 可调用 kimi_web_fetch 读取网页",
        "default": true
      },
      "enable_skill": {
        "type": "bool",
        "description": "安装 Skill",
        "hint": "启用后将 Skill 安装到 AstrBot skills，同时移除 LLM Tool",
        "default": false
      }
    }
  }
}
