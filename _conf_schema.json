{
  "connection_settings": {
    "type": "object",
    "description": "连接设置",
    "hint": "Kimi API 联网搜索连接参数",
    "items": {
      "api_mode": {
        "type": "string",
        "description": "API 模式",
        "hint": "builtin_web_search 使用 Kimi 官方 Chat Completions $web_search；coding_endpoints 使用 Kimi CLI/coding endpoint，需配置兼容 UA",
        "default": "builtin_web_search",
        "options": [
          "builtin_web_search",
          "coding_endpoints"
        ]
      },
      "api_key": {
        "type": "string",
        "description": "Kimi API Key",
        "hint": "标准 Kimi API 使用 Moonshot API Key；coding_endpoints 模式使用对应可访问接口的密钥。",
        "default": ""
      },
      "chat_base_url": {
        "type": "string",
        "description": "Chat Completions Base URL",
        "hint": "标准 Kimi API 默认地址；如果使用兼容服务可改为对应 base URL",
        "default": "https://api.moonshot.cn/v1"
      },
      "model": {
        "type": "string",
        "description": "模型 ID",
        "hint": "标准联网搜索建议使用支持 $web_search 的 Kimi 模型，例如 kimi-k2.6",
        "default": "kimi-k2.6"
      },
      "search_url": {
        "type": "string",
        "description": "Coding Search API 地址",
        "hint": "仅 coding_endpoints 模式使用",
        "default": "https://api.kimi.com/coding/v1/search"
      },
      "fetch_url": {
        "type": "string",
        "description": "Coding Fetch API 地址",
        "hint": "仅 coding_endpoints 模式使用",
        "default": "https://api.kimi.com/coding/v1/fetch"
      },
      "timeout_seconds": {
        "type": "int",
        "description": "请求超时时间（秒）",
        "default": 30,
        "slider": {
          "min": 5,
          "max": 120,
          "step": 1
        }
      },
      "reuse_session": {
        "type": "bool",
        "description": "复用 HTTP 会话",
        "hint": "高频调用时可开启，降低连接开销",
        "default": false
      },
      "proxy": {
        "type": "string",
        "description": "HTTP 代理",
        "hint": "例如 http://127.0.0.1:7890，留空则不使用代理",
        "default": ""
      },
      "user_agent": {
        "type": "string",
        "description": "自定义 User-Agent",
        "hint": "标准 Kimi API 通常留空；coding_endpoints 模式可填 KimiCLI/1.30.0",
        "default": ""
      }
    }
  },
  "request_settings": {
    "type": "object",
    "description": "请求设置",
    "hint": "控制搜索数量和正文抓取",
    "items": {
      "default_limit": {
        "type": "int",
        "description": "默认搜索结果数量",
        "hint": "仅 coding_endpoints 模式使用，范围 1-20",
        "default": 8,
        "slider": {
          "min": 1,
          "max": 20,
          "step": 1
        }
      },
      "include_content": {
        "type": "bool",
        "description": "搜索时抓取页面正文",
        "hint": "仅 coding_endpoints 模式使用；标准模式由 $web_search 自动处理",
        "default": false
      },
      "max_content_chars": {
        "type": "int",
        "description": "单次返回正文最大字符数",
        "default": 4000,
        "slider": {
          "min": 500,
          "max": 12000,
          "step": 500
        }
      },
      "max_tokens": {
        "type": "int",
        "description": "最大输出 Token",
        "hint": "标准 $web_search 模式使用",
        "default": 8192,
        "slider": {
          "min": 1024,
          "max": 32768,
          "step": 1024
        }
      },
      "temperature": {
        "type": "float",
        "description": "温度",
        "default": 0.6,
        "slider": {
          "min": 0,
          "max": 1,
          "step": 0.1
        }
      },
      "disable_thinking": {
        "type": "bool",
        "description": "禁用思考能力",
        "hint": "Kimi 官方文档要求使用 $web_search 时禁用思考能力",
        "default": true
      },
      "max_tool_rounds": {
        "type": "int",
        "description": "最大工具调用轮数",
        "hint": "标准 $web_search 模式使用，防止异常循环",
        "default": 6,
        "slider": {
          "min": 1,
          "max": 12,
          "step": 1
        }
      }
    }
  },
  "tool_settings": {
    "type": "object",
    "description": "工具设置",
    "hint": "控制 LLM Tool 和 Skill",
    "items": {
      "enable_fetch": {
        "type": "bool",
        "description": "启用网页抓取工具",
        "hint": "启用后 AI 可调用 kimi_web_fetch 读取网页正文",
        "default": true
      },
      "enable_skill": {
        "type": "bool",
        "description": "安装 Skill",
        "hint": "启用后将 Skill 安装到 AstrBot skills，同时移除 LLM Tool",
        "default": false
      }
    }
  }
}
