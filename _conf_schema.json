{
  "connection_settings": {
    "type": "object",
    "description": "连接设置",
    "hint": "Kimi coding search/fetch 直连工具参数",
    "items": {
      "api_key": {
        "type": "string",
        "description": "Kimi coding plan API Key",
        "hint": "用于 /coding/v1/search 和 /coding/v1/fetch",
        "default": ""
      },
      "search_url": {
        "type": "string",
        "description": "Search API URL",
        "hint": "kimi_web_search 使用的直连搜索接口",
        "default": "https://api.kimi.com/coding/v1/search"
      },
      "fetch_url": {
        "type": "string",
        "description": "Fetch API URL",
        "hint": "kimi_web_fetch 使用的直连网页抓取接口",
        "default": "https://api.kimi.com/coding/v1/fetch"
      },
      "timeout_seconds": {
        "type": "int",
        "description": "请求超时时间（秒）",
        "default": 60,
        "slider": {
          "min": 5,
          "max": 180,
          "step": 1
        }
      },
      "reuse_session": {
        "type": "bool",
        "description": "复用 HTTP 会话",
        "hint": "高频调用时可开启，降低连接开销",
        "default": false
      },
      "proxy": {
        "type": "string",
        "description": "HTTP 代理",
        "hint": "例如 http://127.0.0.1:7890，留空则不使用代理",
        "default": ""
      },
      "user_agent": {
        "type": "string",
        "description": "User-Agent",
        "hint": "coding plan 默认使用 KimiCLI/1.30.0",
        "default": "KimiCLI/1.30.0"
      }
    }
  },
  "request_settings": {
    "type": "object",
    "description": "请求设置",
    "hint": "控制搜索和输出",
    "items": {
      "default_limit": {
        "type": "int",
        "description": "默认搜索结果数量",
        "hint": "范围 1-20",
        "default": 8,
        "slider": {
          "min": 1,
          "max": 20,
          "step": 1
        }
      },
      "include_content": {
        "type": "bool",
        "description": "搜索时抓取页面正文",
        "hint": "会返回更多内容，也会消耗更多上下文",
        "default": false
      },
      "max_content_chars": {
        "type": "int",
        "description": "正文最大返回字符数",
        "default": 4000,
        "slider": {
          "min": 500,
          "max": 12000,
          "step": 500
        }
      }
    }
  },
  "tool_settings": {
    "type": "object",
    "description": "工具设置",
    "hint": "控制 LLM Tool 和 Skill",
    "items": {
      "enable_fetch": {
        "type": "bool",
        "description": "启用网页获取工具",
        "hint": "启用后 AI 可调用 kimi_web_fetch 读取网页",
        "default": true
      },
      "enable_skill": {
        "type": "bool",
        "description": "安装 Skill",
        "hint": "启用后将 Skill 安装到 AstrBot skills，同时移除 LLM Tool",
        "default": false
      }
    }
  }
}
